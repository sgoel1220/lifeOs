DATABASE_URL="postgresql://username:password@host:port/database"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
# Optional locally. On Railway, auth can auto-resolve URL from Railway env vars.
BETTER_AUTH_URL="http://localhost:3000"

# Chrome Extension auth (optional)
# Generate with: openssl rand -base64 32
EXTENSION_API_KEY="replace-with-a-long-random-secret"
# Your user ID — find it by logging in and checking /api/whoami, or from DB
EXTENSION_USER_ID="your-user-id-here"

# AI Processing
OPENROUTER_API_KEY="sk-or-..."
AI_MODEL="anthropic/claude-haiku-4-5"

# Internal API key for fire-and-forget processing (openssl rand -base64 32)
INTERNAL_API_KEY="replace-with-a-long-random-secret"

# App URL (used for internal API calls)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
