{
  "manifest_version": 3,
  "name": "LifeOS Capture",
  "version": "1.0.0",
  "description": "Capture thoughts and web context into your LifeOS. Type or dictate.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://lifeos-web-production.up.railway.app/*",
    "https://lifeos-web-staging.up.railway.app/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LifeOS Capture",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
